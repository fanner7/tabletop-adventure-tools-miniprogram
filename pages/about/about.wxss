page {
  background: #f5f0e8;
}
.page {
  min-height: 100vh;
  background: #f5f0e8;
  padding: 24rpx 24rpx 80rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

/* Hero */
.hero {
  text-align: center;
  padding: 48rpx 28rpx;
}
.hero-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 12rpx;
}
.hero-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #3b2e1e;
  display: block;
}
.hero-sub {
  font-size: 22rpx;
  color: #8b7355;
  display: block;
  margin-top: 6rpx;
}
.hero-ver {
  font-size: 22rpx;
  color: #b0a590;
  display: block;
  margin-top: 10rpx;
}

/* Sections */
.section-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #3b2e1e;
  display: block;
  margin-bottom: 12rpx;
}
.section-text {
  font-size: 26rpx;
  color: #5a4a3a;
  line-height: 1.8;
  display: block;
}

/* Tags */
.tag-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}
.tag {
  display: inline-block;
  padding: 8rpx 18rpx;
  background: #f5f0e8;
  border: 1rpx solid #d4c5a9;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #6b4c2a;
}

/* Link */
.link-row {
  margin: 14rpx 0;
  padding: 16rpx 20rpx;
  background: #faf8f4;
  border: 1rpx solid #d4c5a9;
  border-radius: 10rpx;
  text-align: center;
}
.link-row:active {
  background: #f0ece5;
}
.link-text {
  font-size: 24rpx;
  color: #6b4c2a;
}

.footnote {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #b0a590;
}
