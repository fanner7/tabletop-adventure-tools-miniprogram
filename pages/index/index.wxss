/** pages/index/index.wxss — 工具箱主页样式 **/

page {
  padding-top: 90rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fdf6ee 0%, #f2e8d9 100%);
  color: #3b2e1e;
  min-height: 100vh;
}

.page-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 0 20px;
  box-sizing: border-box;
}

/* 顶部标题区 */
.header {
  text-align: center;
  padding: 20rpx 20px 28rpx;
  max-width: 800px;
  width: 100%;
}

.header-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #3b2e1e;
  letter-spacing: 3px;
  display: block;
  margin-bottom: 8px;
  text-shadow: 0 1px 2px rgba(139,69,19,0.15);
}

.header-subtitle {
  font-size: 22rpx;
  color: #a08060;
  letter-spacing: 1px;
  display: block;
}

/* 导航卡片网格 */
.grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 10px;
  max-width: 700px;
  width: 100%;
  box-sizing: border-box;
}

.card {
  background: linear-gradient(160deg, #fffdf8 0%, #faf5ec 100%);
  border-radius: 14px;
  padding: 20px 12px;
  width: 48%;
  margin-bottom: 14px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  border: 1px solid #e8ddce;
  box-shadow:
    0 2px 4px rgba(139,100,60,0.08),
    0 1px 0 rgba(255,255,255,0.6) inset;
  transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
}

.card:active {
  transform: translateY(-4rpx);
  box-shadow:
    0 6px 18px rgba(139,100,60,0.18),
    0 1px 0 rgba(255,255,255,0.6) inset;
  border-color: #c4a882;
}

.card-icon {
  font-size: 46rpx;
  margin-bottom: 10px;
  filter: drop-shadow(0 2px 2px rgba(139,69,19,0.12));
}

.card-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #3b2e1e;
  margin: 4px 0;
  display: block;
}

.card-desc {
  font-size: 20rpx;
  line-height: 1.5;
  color: #9b8b7a;
  display: block;
}

/* 底部标语 — 水印质感 */
.slogan {
  margin-top: 10rpx;
  padding: 20rpx;
  text-align: center;
}
.slogan-text {
  font-size: 28rpx;
  letter-spacing: 8rpx;
  color: #c8b89a;
  text-shadow:
    0 1px 0 rgba(255,255,255,0.5),
    0 -1px 0 rgba(180,160,140,0.3);
}

/* 底部安全区 */
.footer-safe {
  height: 40px;
}
