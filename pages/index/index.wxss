/** pages/index/index.wxss — 工具箱主页样式（白天模式） **/

page {
  background-color: #f5f0e8;
  color: #3b2e1e;
  min-height: 100vh;
}

.page-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 0 20px;
  box-sizing: border-box;
}

/* 顶部标题区 */
.header {
  text-align: center;
  padding: 40rpx 20px 20px;
  max-width: 800px;
  width: 100%;
}

.header-title {
  font-size: 40rpx;
  color: #3b2e1e;
  letter-spacing: 2px;
  display: block;
  margin-bottom: 10px;
}

.header-subtitle {
  font-size: 24rpx;
  color: #8b7355;
  display: block;
}

/* 导航卡片网格 */
.grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 10px;
  max-width: 700px;
  width: 100%;
  box-sizing: border-box;
}

.card {
  background-color: #ffffff;
  border-radius: 10px;
  padding: 16px 10px;
  width: 48%;
  margin-bottom: 14px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  border: 1px solid #e0d6c8;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
}

.card:active {
  transform: translateY(-6rpx);
  box-shadow: 0 6px 16px rgba(0,0,0,0.12);
  border-color: #8b4513;
}

.card-icon {
  font-size: 48rpx;
  margin-bottom: 8px;
}

.card-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #3b2e1e;
  margin: 6px 0;
  display: block;
}

.card-desc {
  font-size: 22rpx;
  line-height: 1.4;
  color: #8b7355;
  display: block;
}

/* 底部安全区 */
.footer-safe {
  height: 40px;
}
