/* pages/coc-keeper/coc-keeper.wxss — COC 守密人助手 */

page {
  padding-top: 90rpx;
  box-sizing: border-box;
  background-color: #f5f0e8;
  color: #2c2c2c;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  min-height: 100vh;
}

.keeper-container {
  width: 100%;
  max-width: 600px;
  margin: 0 auto;
  padding: 0 16px 120px;
  box-sizing: border-box;
}

/* ===== 顶部标题 ===== */
.keeper-header { text-align: center; padding: 40rpx 0 20rpx; border-bottom: 2px solid #d4c5a9; margin-bottom: 20rpx; }
.keeper-title { font-size: 40rpx; font-weight: bold; color: #3b2e1e; display: block; }
.keeper-subtitle { font-size: 24rpx; color: #7a6b58; display: block; margin-top: 8rpx; }

/* ===== 通用区域标题 ===== */
.section-title { font-size: 30rpx; font-weight: bold; color: #3b2e1e; margin-bottom: 12rpx; display: block; }
.section-desc { font-size: 24rpx; color: #8b7355; margin-bottom: 20rpx; display: block; }

/* ===== 按钮 ===== */
.btn { width: 100%; padding: 28rpx 0; border-radius: 12rpx; font-size: 32rpx; font-weight: bold; text-align: center; border: none; margin-bottom: 16rpx; }
.btn-primary { background: #6b4c2a; color: #fff; }
.btn-primary:active { background: #5a3e22; }
.btn-secondary { background: transparent; color: #6b4c2a; border: 2px solid #6b4c2a; }
.btn-secondary:active { background: #f5f0e8; }
.btn-half { width: calc(50% - 10rpx); display: inline-block; font-size: 28rpx; padding: 22rpx 0; }

/* 低调小按钮 — 导入/战斗轮专用 */
.btn-subtle {
  width: auto;
  display: inline-block;
  padding: 14rpx 28rpx;
  font-size: 24rpx;
  font-weight: normal;
  border-radius: 8rpx;
  border: 1px solid #d4c5a9;
  background: #faf8f4;
  color: #7a6b58;
}
.btn-subtle:active { background: #f0e8d8; }
.btn-subtle.btn-half { padding: 14rpx 0; text-align: center; }

.import-buttons { display: flex; gap: 16rpx; margin-bottom: 16rpx; }

/* ===== 任务列表 ===== */
.task-list { margin-top: 16rpx; }
.task-item {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.task-info { flex: 1; }
.task-name { font-size: 30rpx; font-weight: bold; color: #3b2e1e; display: block; }
.task-meta { font-size: 24rpx; color: #8b7355; margin-top: 4rpx; display: block; }
.task-delete { font-size: 40rpx; color: #c4b8a8; padding: 8rpx 12rpx; }

/* ===== 任务内顶栏 ===== */
.task-header-bar {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 20rpx 0;
  border-bottom: 2px solid #d4c5a9;
  margin-bottom: 20rpx;
}
.back-btn { font-size: 28rpx; color: #6b4c2a; padding: 4rpx 8rpx; }
.task-header-name { font-size: 32rpx; font-weight: bold; color: #3b2e1e; flex: 1; }
.task-header-count { font-size: 22rpx; color: #8b7355; }

/* ===== 卡片网格 ===== */
.card-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.char-card {
  width: calc(50% - 8rpx);
  background: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  transition: transform 0.2s;
}
.char-card:active { transform: translateY(-2rpx); }
.char-card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.char-card-name { font-size: 28rpx; font-weight: bold; color: #3b2e1e; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 80%; }
.char-card-delete { font-size: 32rpx; color: #c4b8a8; padding: 0 4rpx; }
.char-card-occ { font-size: 22rpx; color: #8b7355; display: block; margin-bottom: 8rpx; }
.char-card-stats { display: flex; gap: 8rpx; flex-wrap: wrap; }
.char-card-stat { font-size: 20rpx; color: #6b4c2a; background: #faf6f0; border-radius: 6rpx; padding: 4rpx 10rpx; }
.npc-card { border-left: 4rpx solid #c4b8a8; }
.npc-card-preview { font-size: 22rpx; color: #7a6b58; line-height: 1.5; display: block; margin-top: 8rpx; }

/* 空状态 */
.empty-hint { text-align: center; padding: 40rpx 0; color: #c4b8a8; font-size: 26rpx; }

/* ================================================================== */
/* 角色卡样式（精确复刻 coc7-gen step 5） */
/* ================================================================== */

/* swiper 容器 — 占据剩余高度 */
.detail-swiper { height: calc(100vh - 220rpx); }
.detail-scroll { height: 100%; }

.char-sheet { background: #fff; border-radius: 16rpx; padding: 24rpx; box-shadow: 0 2px 12px rgba(0,0,0,0.1); }
.char-header { text-align: center; border-bottom: 2px solid #3b2e1e; padding-bottom: 16rpx; margin-bottom: 16rpx; }
.char-name { font-size: 36rpx; font-weight: bold; color: #3b2e1e; display: block; }
.char-sub { font-size: 24rpx; color: #7a6b58; display: block; margin-top: 4rpx; }

.char-section-title { font-size: 28rpx; font-weight: bold; color: #6b4c2a; border-bottom: 1px solid #d4c5a9; padding-bottom: 8rpx; margin: 20rpx 0 12rpx; display: block; }

/* 属性 — 2列 grid，每行 label 左 value 右 */
.char-attr-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8rpx; }
.char-attr { display: flex; justify-content: space-between; padding: 8rpx 12rpx; background: #faf8f4; border-radius: 8rpx; font-size: 26rpx; }
.char-attr-label { color: #7a6b58; }
.char-attr-value { font-weight: bold; color: #3b2e1e; }

/* 派生状态 — flex-wrap，每项 flex:1 */
.char-deriv-row { display: flex; gap: 12rpx; flex-wrap: wrap; }
.char-deriv { flex: 1; min-width: 110rpx; text-align: center; padding: 12rpx; background: #fdf5e6; border-radius: 8rpx; }
.char-deriv-label { font-size: 22rpx; color: #8b7355; display: block; }
.char-deriv-value { font-size: 32rpx; font-weight: bold; color: #3b2e1e; display: block; margin-top: 4rpx; }

/* 技能分类标题 — 匹配原版 */
.skill-cat-title { font-size: 26rpx; font-weight: bold; color: #6b4c2a; display: block; padding: 14rpx 0 8rpx 8rpx; border-bottom: 1px solid #d4c5a9; margin-top: 16rpx; }
.skill-cat-title:first-of-type { margin-top: 0; }

/* 技能 2列 grid */
.skill-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10rpx; padding: 10rpx 0; }
.skill-grid-item { background: #fff; border-radius: 10rpx; padding: 14rpx; box-shadow: 0 1px 4px rgba(0,0,0,0.05); }
.skill-grid.review .skill-grid-item { background: #faf8f4; padding: 10rpx 14rpx; }
.skill-grid-top { display: flex; justify-content: space-between; align-items: center; }
.skill-grid-name { font-size: 26rpx; color: #3b2e1e; font-weight: bold; }
.skill-grid-val { font-size: 30rpx; font-weight: bold; color: #6b4c2a; }

/* 武器表 */
.weapon-table { background: #fff; border-radius: 8rpx; overflow: hidden; margin-bottom: 12rpx; }
.weapon-row { display: flex; align-items: center; padding: 10rpx 12rpx; border-bottom: 1px solid #eee8dd; }
.weapon-row:last-child { border-bottom: none; }
.weapon-header { background: #fdf5e6; }
.weapon-header .weapon-cell { font-weight: bold; color: #6b4c2a; font-size: 22rpx; }
.weapon-cell { font-size: 22rpx; color: #3b2e1e; }
.w-name { flex: 2.5; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.w-skill { flex: 1; text-align: center; }
.w-dmg { flex: 1.1; text-align: center; }
.w-range { flex: 0.8; text-align: center; }
.w-impale { flex: 0.5; text-align: center; }
.w-attacks { flex: 0.6; text-align: center; }
.w-ammo { flex: 0.6; text-align: center; }
.w-malfunc { flex: 0.6; text-align: center; }

.weapon-empty { text-align: center; padding: 20rpx 0; }
.weapon-empty-text { font-size: 24rpx; color: #aaa; }

/* 文本块 */
.char-text-block { background: #faf8f4; border: 1px solid #e8e0d6; border-radius: 8rpx; padding: 14rpx 16rpx; font-size: 26rpx; color: #3b2e1e; line-height: 1.7; white-space: pre-wrap; word-break: break-all; }
.npc-text { min-height: 200rpx; }

/* ===== 战斗轮排序（内联） ===== */
.combat-bar { margin-bottom: 16rpx; }
.combat-bar .btn-subtle { width: 100%; box-sizing: border-box; text-align: center; }
.combat-inline { margin-top: 8rpx; }
.combat-tie-warn {
  background: #fff3cd;
  border: 1px solid #ffc107;
  border-radius: 6rpx;
  padding: 8rpx 12rpx;
  margin-bottom: 10rpx;
}
.combat-tie-warn text { font-size: 22rpx; color: #856404; line-height: 1.4; }
.combat-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.combat-tag {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: bold;
}
.combat-tag.player { background: #e8f0fe; color: #1a56b8; border: 1.5px solid #b8d4fe; }
.combat-tag.npc { background: #fce4ec; color: #b71c1c; border: 1.5px solid #f8bbd0; }
.combat-tag.tie { border-style: dashed; box-shadow: 0 0 0 2px #ffc107; }
.combat-tag-idx {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.12);
  font-size: 18rpx;
  flex-shrink: 0;
}
.combat-tag-name { flex: 1; }
.combat-tag-dex { font-size: 18rpx; opacity: 0.7; font-weight: normal; }

/* ===== Dialog 通用 ===== */
.dialog-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 200;
  opacity: 0; visibility: hidden;
  transition: opacity 0.3s, visibility 0.3s;
}
.dialog-overlay.active { opacity: 1; visibility: visible; }

.dialog-sheet {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 201;
  transform: translateY(100%);
  transition: transform 0.3s ease-out;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}
.dialog-sheet.active { transform: translateY(0); }

.dialog-handle {
  width: 60rpx; height: 6rpx;
  background: #d4c5a9;
  border-radius: 3rpx;
  margin: 16rpx auto;
}

.dialog-title { font-size: 32rpx; font-weight: bold; color: #3b2e1e; text-align: center; padding: 0 32rpx 16rpx; display: block; }
.dialog-hint { font-size: 24rpx; color: #8b7355; line-height: 1.6; display: block; }

.dialog-body-padded { padding: 0 32rpx 16rpx; flex: 1; overflow-y: auto; }

.dialog-actions { display: flex; gap: 16rpx; padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom, 20rpx)); }
.dialog-btn { flex: 1; padding: 24rpx 0; border-radius: 12rpx; font-size: 28rpx; font-weight: bold; text-align: center; border: none; }
.dialog-btn.confirm { background: #6b4c2a; color: #fff; }
.dialog-btn.confirm:active { background: #5a3e22; }
.dialog-btn.cancel { background: #f0e8d8; color: #6b4c2a; }
.dialog-btn.cancel:active { background: #e8ddce; }

/* 表单（复用 coc7-gen 样式） */
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 28rpx; color: #3b2e1e; display: block; margin-bottom: 8rpx; font-weight: bold; }
.form-input {
  width: 100%; height: 88rpx;
  background: #faf8f4;
  border: 2px solid #d4c5a9;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx; color: #3b2e1e;
  box-sizing: border-box;
}
.form-input:focus { border-color: #8b7355; }
